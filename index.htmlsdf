<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VidNest Player</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/hls.js/1.5.7/hls.min.js"></script>
<style>
  :root {
    --bg:      #0a0a0f;
    --surface: #111118;
    --border:  #1e1e2e;
    --accent:  #7c6aff;
    --accent2: #a78bfa;
    --text:    #e2e8f0;
    --muted:   #64748b;
    --ok:      #4ade80;
    --err:     #f87171;
    --warn:    #fb923c;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--bg); color:var(--text); font-family:'Segoe UI',system-ui,sans-serif; min-height:100vh; }

  header { padding:14px 24px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:12px; }
  header svg { width:26px; height:26px; flex-shrink:0; }
  header h1 { font-size:1rem; font-weight:700; letter-spacing:.5px; color:var(--accent2); }
  #hdr-status { font-size:.72rem; color:var(--muted); margin-left:auto; }

  .wrap { display:grid; grid-template-columns:1fr 330px; height:calc(100vh - 53px); }
  @media(max-width:860px){ .wrap{ grid-template-columns:1fr; grid-template-rows:auto 1fr; } }

  /* ── Player side ── */
  .player-side { display:flex; flex-direction:column; padding:16px; gap:12px; overflow-y:auto; }

  /* Manual URL bar */
  .url-bar { display:flex; gap:6px; }
  .url-bar input { flex:1; background:var(--surface); border:1px solid var(--border); color:var(--text);
    padding:9px 12px; border-radius:8px; font-size:.82rem; font-family:monospace; outline:none; }
  .url-bar input:focus { border-color:var(--accent); }
  .url-bar select { background:var(--surface); border:1px solid var(--border); color:var(--text);
    padding:9px 8px; border-radius:8px; font-size:.8rem; outline:none; cursor:pointer; }
  .url-bar button { background:var(--accent); color:#fff; border:none; border-radius:8px;
    padding:9px 16px; font-size:.82rem; font-weight:600; cursor:pointer; white-space:nowrap; }
  .url-bar button:hover { background:var(--accent2); }

  /* Advanced options (referer/origin) - hidden by default */
  .adv-toggle { font-size:.72rem; color:var(--muted); cursor:pointer; user-select:none;
    display:flex; align-items:center; gap:5px; width:fit-content; }
  .adv-toggle:hover { color:var(--accent2); }
  .adv-toggle .arrow { transition:transform .2s; display:inline-block; }
  .adv-toggle.open .arrow { transform:rotate(90deg); }
  .adv-section { display:none; background:var(--surface); border:1px solid var(--border);
    border-radius:8px; padding:10px 12px; gap:8px; flex-direction:column; }
  .adv-section.visible { display:flex; }
  .adv-row { display:flex; align-items:center; gap:8px; }
  .adv-row label { font-size:.72rem; color:var(--muted); width:56px; flex-shrink:0; }
  .adv-row input { flex:1; background:var(--bg); border:1px solid var(--border); color:var(--text);
    padding:6px 10px; border-radius:6px; font-size:.78rem; font-family:monospace; outline:none; }
  .adv-row input:focus { border-color:var(--accent); }
  .adv-note { font-size:.68rem; color:var(--muted); }

  /* Video / iframe container */
  .media-wrap { position:relative; background:#000; border-radius:12px; overflow:hidden; aspect-ratio:16/9; width:100%; flex-shrink:0; }
  video { width:100%; height:100%; display:block; }
  #iframe-player { width:100%; height:100%; border:none; display:none; background:#000; }
  .video-overlay { position:absolute; inset:0; display:flex; flex-direction:column;
    align-items:center; justify-content:center; gap:10px; pointer-events:none; background:rgba(0,0,0,.6); }
  .video-overlay.hidden { display:none; }
  .spinner { width:38px; height:38px; border:3px solid var(--border); border-top-color:var(--accent);
    border-radius:50%; animation:spin .7s linear infinite; }
  @keyframes spin { to{ transform:rotate(360deg); } }
  .overlay-msg { font-size:.8rem; color:var(--muted); text-align:center; padding:0 20px; }

  /* Status / type badge */
  .status-bar { font-size:.72rem; color:var(--muted); display:flex; gap:10px; flex-wrap:wrap; align-items:center; }
  .dot { width:7px; height:7px; border-radius:50%; display:inline-block; margin-right:4px; flex-shrink:0; }
  .dot.ok  { background:var(--ok); }  .dot.err { background:var(--err); }  .dot.warn { background:var(--warn); }
  .media-type-badge { font-size:.65rem; font-weight:700; border-radius:4px; padding:2px 7px; }
  .badge-hls   { background:#2a1f0a; color:var(--warn); }
  .badge-mp4   { background:#0a2a14; color:var(--ok); }
  .badge-txt   { background:#1a1535; color:var(--accent2); }
  .badge-embed { background:#0a1f2a; color:#38bdf8; }
  .badge-dash  { background:#1a0a2a; color:#c084fc; }

  /* ── Source panel ── */
  .source-panel { border-left:1px solid var(--border); display:flex; flex-direction:column; overflow:hidden; }
  @media(max-width:860px){ .source-panel{ border-left:none; border-top:1px solid var(--border); max-height:44vh; } }

  .panel-head { padding:12px 14px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:8px; flex-shrink:0; }
  .panel-head h2 { font-size:.82rem; font-weight:700; }
  .panel-head .cnt { margin-left:auto; background:var(--accent); color:#fff;
    font-size:.62rem; font-weight:700; border-radius:20px; padding:2px 8px; }

  .fetch-bar { padding:10px 12px; border-bottom:1px solid var(--border); display:flex; flex-direction:column; gap:7px; flex-shrink:0; }
  .fetch-row { display:flex; gap:5px; }
  .fetch-row input  { flex:1; background:var(--surface); border:1px solid var(--border); color:var(--text);
    padding:7px 9px; border-radius:7px; font-size:.78rem; outline:none; }
  .fetch-row input:focus { border-color:var(--accent); }
  .fetch-row select { background:var(--surface); border:1px solid var(--border); color:var(--text);
    padding:7px 6px; border-radius:7px; font-size:.78rem; outline:none; }
  .fetch-row button { background:var(--accent); color:#fff; border:none; border-radius:7px;
    padding:7px 13px; font-size:.78rem; font-weight:600; cursor:pointer; }
  .fetch-row button:hover { background:var(--accent2); }
  .ep-row { display:flex; gap:5px; }
  .ep-row input { flex:1; background:var(--surface); border:1px solid var(--border); color:var(--text);
    padding:6px 9px; border-radius:7px; font-size:.76rem; outline:none; }

  .fetch-status { font-size:.7rem; padding:5px 12px; color:var(--muted); min-height:20px; flex-shrink:0; }
  .fetch-status.ok   { color:var(--ok); }
  .fetch-status.err  { color:var(--err); }
  .fetch-status.warn { color:var(--warn); }

  /* Stream list */
  .stream-list { flex:1; overflow-y:auto; padding:8px 6px; display:flex; flex-direction:column; gap:3px; }
  .stream-list:empty::after { content:"No streams loaded."; display:block; text-align:center;
    color:var(--muted); font-size:.75rem; padding:28px 0; }

  .server-group { margin-bottom:4px; }
  .server-label { font-size:.65rem; font-weight:700; color:var(--muted); text-transform:uppercase;
    letter-spacing:1px; padding:5px 8px 3px; }

  .stream-item { display:flex; align-items:center; gap:5px; padding:6px 7px; border-radius:7px;
    cursor:pointer; border:1px solid transparent; transition:all .12s; }
  .stream-item:hover  { background:var(--surface); border-color:var(--border); }
  .stream-item.active { background:#1a1535; border-color:var(--accent); }
  .type-tag { font-size:.6rem; font-weight:700; border-radius:4px; padding:2px 5px; white-space:nowrap; flex-shrink:0; }
  .type-tag.hls   { background:#2a1f0a; color:var(--warn); }
  .type-tag.mp4   { background:#0a2a14; color:var(--ok); }
  .type-tag.dash  { background:#1a0a2a; color:#c084fc; }
  .type-tag.txt   { background:#1a1535; color:var(--accent2); }
  .type-tag.embed { background:#0a1f2a; color:#38bdf8; }
  .stream-url-text { font-size:.65rem; color:var(--muted); white-space:nowrap;
    overflow:hidden; text-overflow:ellipsis; flex:1; min-width:0; }
  .stream-item.active .stream-url-text { color:var(--accent2); }
  .play-icon { flex-shrink:0; color:var(--accent); font-size:.75rem; opacity:0; }
  .stream-item:hover .play-icon, .stream-item.active .play-icon { opacity:1; }

  ::-webkit-scrollbar { width:4px; } ::-webkit-scrollbar-track { background:transparent; }
  ::-webkit-scrollbar-thumb { background:var(--border); border-radius:3px; }
</style>
</head>
<body>

<header>
  <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="14" cy="14" r="13" fill="#1a1535" stroke="#7c6aff" stroke-width="1.5"/>
    <polygon points="11,9 21,14 11,19" fill="#a78bfa"/>
  </svg>
  <h1>VidNest Player</h1>
  <span id="hdr-status">idle</span>
</header>

<div class="wrap">

  <!-- ── Left: player ── -->
  <div class="player-side">

    <!-- URL bar with type selector -->
    <div class="url-bar">
      <input id="manualUrl" placeholder="Paste m3u8 / mp4 / .txt / embed URL…" />
      <select id="manualType" title="Force media type">
        <option value="auto">Auto</option>
        <option value="hls">HLS</option>
        <option value="mp4">MP4</option>
        <option value="dash">DASH</option>
        <option value="txt">TXT</option>
        <option value="embed">Embed</option>
      </select>
      <button onclick="playManual()">▶ Play</button>
    </div>

    <!-- Advanced: Referer / Origin (hidden by default) -->
    <div>
      <div class="adv-toggle" id="advToggle" onclick="toggleAdv()">
        <span class="arrow">▶</span> Advanced headers
      </div>
      <div class="adv-section" id="advSection">
        <div class="adv-row">
          <label>Referer</label>
          <input id="referer" type="url" placeholder="https://example.com/" />
        </div>
        <div class="adv-row">
          <label>Origin</label>
          <input id="origin" type="url" placeholder="https://example.com" />
        </div>
        <div class="adv-note">⚠ Headers apply to HLS fetches via hls.js xhrSetup. Embed iframes ignore them.</div>
      </div>
    </div>

    <!-- Media container -->
    <div class="media-wrap" id="mediaWrap">
      <video id="vid" controls></video>
      <iframe id="iframe-player" allowfullscreen allow="autoplay; fullscreen"></iframe>
      <div class="video-overlay" id="overlay">
        <div class="spinner" id="spinner" style="display:none"></div>
        <div class="overlay-msg" id="overlayMsg">Select a stream or paste a URL above</div>
      </div>
    </div>

    <div class="status-bar" id="statusBar">
      <span><span class="dot warn"></span>No stream loaded</span>
    </div>
  </div>

  <!-- ── Right: source panel ── -->
  <div class="source-panel">
    <div class="panel-head">
      <h2>Streams</h2>
      <span class="cnt" id="totalBadge">0</span>
    </div>
    <div class="fetch-bar">
      <div class="fetch-row">
        <input id="tmdbId" type="number" placeholder="TMDB ID" value="280" style="width:85px;flex:none"/>
        <select id="mtype">
          <option value="movie">Movie</option>
          <option value="tv">TV</option>
        </select>
        <button onclick="fetchStreams()">Fetch</button>
      </div>
      <div class="ep-row" id="epRow" style="display:none">
        <input id="season"  type="number" placeholder="Season"  value="1"/>
        <input id="episode" type="number" placeholder="Episode" value="1"/>
      </div>
    </div>
    <div class="fetch-status" id="fetchStatus">Enter a TMDB ID and click Fetch.</div>
    <div class="stream-list" id="streamList"></div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════════════════════
// VidNest resolver (embedded — hits new.vidnest.fun directly)
// ═══════════════════════════════════════════════════════════════════
const ALPHA = "RB0fpH8ZEyVLkv7c2i6MAJ5u3IKFDxlS1NTsnGaqmXYdUrtzjwObCgQP94hoeW+/=";
const SERVERS = {
  catflix:"movies4f", ophim:"klikxxi",    alfa:"moviesapi",
  beta:"purstream",   lamda:"allmovies",  prime:"catflix",
  hexa:"vidlink",     sigma:"hollymoviehd", gama:"flixhq", delta:"allmovies",
};
const PROXY_LIST = [
  { name:"corsproxy.io",  wrap: u=>`https://corsproxy.io/?url=${encodeURIComponent(u)}` },
  { name:"allorigins",    wrap: u=>`https://api.allorigins.win/raw?url=${encodeURIComponent(u)}` },
  { name:"codetabs",      wrap: u=>`https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(u)}` },
  { name:"htmldriven",    wrap: u=>`https://cors.htmldriven.com/?url=${encodeURIComponent(u)}` },
  { name:"thingproxy",    wrap: u=>`https://thingproxy.freeboard.io/fetch/${u}` },
  { name:"corsanywhere",  wrap: u=>`https://cors-anywhere.herokuapp.com/${u}` },
];
const SUBTITLE_HOSTS = ["opensubtitles.org","opensubtitles.com","wyzie.io","vdrk.site"];
const SUBTITLE_EXTS  = [".vtt",".srt",".ass",".ssa"];
let activeProxy = null;
let hlsPlayer   = null;
let activeItem  = null;

function decode(data) {
  const val={};
  for(let i=0;i<ALPHA.length;i++) val[ALPHA[i]]=i;
  data=data.replace(/\s+/g,"");
  const out=[];
  for(let i=0;i<data.length;i+=4){
    const chunk=(data.slice(i,i+4)+"====").slice(0,4);
    const n=chunk.split("").map(c=>val[c]??64);
    out.push((n[0]<<2)|(n[1]>>4));
    if(n[2]!==64) out.push(((n[1]&15)<<4)|(n[2]>>2));
    if(n[3]!==64) out.push(((n[2]&3)<<6)|n[3]);
  }
  return JSON.parse(new TextDecoder().decode(new Uint8Array(out)));
}
function isSub(url) {
  const u=url.toLowerCase();
  return SUBTITLE_HOSTS.some(h=>u.includes(h))||SUBTITLE_EXTS.some(e=>u.split("?")[0].endsWith(e));
}
function detectType(url) {
  const u = url.toLowerCase().split("?")[0];
  if(u.endsWith(".mp4") || u.endsWith(".webm") || u.endsWith(".mkv")) return "mp4";
  if(u.endsWith(".mpd"))  return "dash";
  if(u.endsWith(".txt"))  return "txt";
  // embed patterns: known embed hosts or no file extension
  if(isEmbedUrl(url))     return "embed";
  return "hls"; // default (.m3u8 or extensionless stream)
}
function isEmbedUrl(url) {
  try {
    const h = new URL(url).hostname;
    const embedHosts = ["goodstream.cc","vidlink.pro","vidsrc.to","vidsrc.me","vidsrc.xyz",
      "embed.su","multiembed.mov","2embed.cc","smashystream.com","moviesapi.club",
      "vidfast.pro","vidnest.fun","warezcdn.link","frembed.hair","filemoon.sx"];
    if(embedHosts.some(e=>h.includes(e))) return true;
    // URL with /embed/ path
    if(new URL(url).pathname.includes("/embed/")) return true;
  } catch{}
  return false;
}
function transformUrl(url) {
  try {
    const u=new URL(url);
    if(u.hostname==="goodstream.cc"){
      const segs=u.pathname.split("/").filter(Boolean);
      if((segs[0]==="streamsvr"||segs[0]==="pl")&&segs[1])
        return `${u.protocol}//${u.hostname}/embed/${segs[1]}`;
    }
  } catch {}
  return url;
}
function extractUrls(obj,found=[]) {
  if(!obj||typeof obj!=="object") return found;
  if(Array.isArray(obj)){obj.forEach(v=>extractUrls(v,found));return found;}
  for(const [k,v] of Object.entries(obj)){
    if((k==="url"||k==="file")&&typeof v==="string"&&v.startsWith("http")){
      if(!isSub(v)) found.push(transformUrl(v));
    } else extractUrls(v,found);
  }
  return found;
}
async function probeProxy(proxy) {
  try {
    const r=await fetch(proxy.wrap("https://new.vidnest.fun/moviesapi/movie/254"),{signal:AbortSignal.timeout(8000)});
    if(!r.ok) return false;
    return !!(await r.json())?.data;
  } catch { return false; }
}
async function findProxy(statusFn) {
  for(const proxy of PROXY_LIST){
    if(statusFn) statusFn(`Trying proxy: ${proxy.name}…`,"warn");
    if(await probeProxy(proxy)){ activeProxy=proxy; return true; }
  }
  return false;
}
async function fetchServer(backend,path) {
  const r=await fetch(activeProxy.wrap(`https://new.vidnest.fun/${backend}/${path}`),{signal:AbortSignal.timeout(14000)});
  if(!r.ok) throw new Error(`HTTP ${r.status}`);
  const raw=await r.json();
  if(!raw?.data) throw new Error("no data field");
  return extractUrls(decode(raw.data));
}

// ═══════════════════════════════════════════════════════════════════
// Advanced toggle
// ═══════════════════════════════════════════════════════════════════
function toggleAdv() {
  const t=document.getElementById("advToggle");
  const s=document.getElementById("advSection");
  t.classList.toggle("open");
  s.classList.toggle("visible");
}

// ═══════════════════════════════════════════════════════════════════
// Fetch streams from VidNest
// ═══════════════════════════════════════════════════════════════════
document.getElementById("mtype").addEventListener("change", function(){
  document.getElementById("epRow").style.display = this.value==="tv" ? "flex" : "none";
});

async function fetchStreams() {
  const tmdb   = document.getElementById("tmdbId").value.trim();
  const mtype  = document.getElementById("mtype").value;
  const season = document.getElementById("season").value || "1";
  const ep     = document.getElementById("episode").value || "1";
  if(!tmdb){ setFetchStatus("Enter a TMDB ID first.", "err"); return; }

  const path = mtype==="movie" ? `movie/${tmdb}` : `tv/${tmdb}/${season}/${ep}`;
  document.getElementById("streamList").innerHTML = "";
  document.getElementById("totalBadge").textContent = "0";
  document.getElementById("hdr-status").textContent = "fetching…";

  if(!activeProxy) {
    setFetchStatus("Finding proxy…", "warn");
    if(!await findProxy(setFetchStatus)){
      setFetchStatus("All proxies failed.", "err");
      document.getElementById("hdr-status").textContent = "error";
      return;
    }
  }

  setFetchStatus(`Resolving via ${activeProxy.name}…`, "warn");

  const jobs = Object.entries(SERVERS).map(async ([name, backend]) => {
    try {
      const urls = await fetchServer(backend, path);
      return { server:name, streams: urls.map(u=>({url:u, type:detectType(u)})) };
    } catch(e) {
      if(e.message.includes("Failed to fetch")||e.message.includes("NetworkError")){
        activeProxy=null;
        if(await findProxy(null)){
          try {
            const urls = await fetchServer(backend, path);
            return { server:name, streams: urls.map(u=>({url:u, type:detectType(u)})) };
          } catch { return null; }
        }
      }
      return null;
    }
  });

  const results = (await Promise.all(jobs)).filter(r => r && r.streams.length > 0);
  const total   = results.reduce((n,r) => n+r.streams.length, 0);

  if(!results.length){
    setFetchStatus("No streams found.", "err");
    document.getElementById("hdr-status").textContent = "no results";
    return;
  }

  renderStreamList(results);
  document.getElementById("totalBadge").textContent = total;
  setFetchStatus(`✓ ${total} stream(s) across ${results.length} server(s)`, "ok");
  document.getElementById("hdr-status").textContent = `${total} streams`;
}

function renderStreamList(servers) {
  const list = document.getElementById("streamList");
  list.innerHTML = "";
  servers.forEach(srv => {
    const group = document.createElement("div");
    group.className = "server-group";
    const label = document.createElement("div");
    label.className = "server-label";
    label.textContent = srv.server;
    group.appendChild(label);
    srv.streams.forEach(s => {
      const item = document.createElement("div");
      item.className = "stream-item";
      item.innerHTML = `
        <span class="type-tag ${s.type}">${s.type.toUpperCase()}</span>
        <span class="stream-url-text" title="${s.url}">${s.url}</span>
        <span class="play-icon">▶</span>`;
      item.addEventListener("click", () => playStream(s.url, s.type, item));
      group.appendChild(item);
    });
    list.appendChild(group);
  });
}

// ═══════════════════════════════════════════════════════════════════
// Media loading — handles HLS / MP4 / DASH / TXT playlist / Embed
// ═══════════════════════════════════════════════════════════════════
function playStream(url, type, itemEl) {
  if(activeItem) activeItem.classList.remove("active");
  activeItem = itemEl;
  if(itemEl) itemEl.classList.add("active");
  document.getElementById("manualUrl").value = url;
  loadMedia(url, type);
}

function playManual() {
  const url = document.getElementById("manualUrl").value.trim();
  if(!url) return;
  let type = document.getElementById("manualType").value;
  if(type === "auto") type = detectType(url);
  if(activeItem) activeItem.classList.remove("active");
  activeItem = null;
  loadMedia(url, type);
}

async function loadMedia(url, type) {
  showOverlay(true, "Loading…");
  setStatus("warn", `Loading ${type.toUpperCase()}…`, url);
  destroyPlayer();

  if(type === "txt") {
    // Fetch .txt, extract first valid m3u8/mp4 URL and play it
    await loadTxtPlaylist(url);
    return;
  }
  if(type === "embed") {
    loadEmbed(url);
    return;
  }
  if(type === "mp4" || type === "webm" || type === "dash") {
    loadNative(url, type);
    return;
  }
  // HLS
  loadHls(url);
}

function destroyPlayer() {
  if(hlsPlayer){ hlsPlayer.destroy(); hlsPlayer=null; }
  const vid = document.getElementById("vid");
  const ifr = document.getElementById("iframe-player");
  vid.pause(); vid.removeAttribute("src"); vid.load();
  vid.style.display = "block";
  ifr.style.display = "none"; ifr.src = "about:blank";
}

function loadHls(url) {
  const vid = document.getElementById("vid");
  const referer = document.getElementById("referer").value.trim();
  const origin  = document.getElementById("origin").value.trim();

  if(Hls.isSupported()) {
    const cfg = { enableWorker:true, lowLatencyMode:false };
    if(referer || origin) {
      cfg.xhrSetup = function(xhr, xhrUrl) {
        if(referer) xhr.setRequestHeader("Referer", referer);
        if(origin)  xhr.setRequestHeader("Origin",  origin);
      };
    }
    hlsPlayer = new Hls(cfg);
    hlsPlayer.loadSource(url);
    hlsPlayer.attachMedia(vid);
    hlsPlayer.on(Hls.Events.MANIFEST_PARSED, () => {
      vid.play().catch(()=>{});
      showOverlay(false);
      setStatus("ok", "Playing HLS", url);
      setTypeBadge("hls");
    });
    hlsPlayer.on(Hls.Events.ERROR, (_, data) => {
      if(data.fatal){ showOverlay(false); setStatus("err", `HLS error: ${data.details}`, url); }
    });
  } else if(vid.canPlayType("application/vnd.apple.mpegurl")) {
    vid.src = url;
    vid.play().catch(()=>{});
    vid.oncanplay = () => { showOverlay(false); setStatus("ok", "Playing HLS (native)", url); setTypeBadge("hls"); };
    vid.onerror   = () => { showOverlay(false); setStatus("err", "Playback error", url); };
  } else {
    showOverlay(false); setStatus("err", "HLS not supported", url);
  }
}

function loadNative(url, type) {
  const vid = document.getElementById("vid");
  vid.src = url;
  vid.play().catch(()=>{});
  vid.oncanplay = () => { showOverlay(false); setStatus("ok", `Playing ${type.toUpperCase()}`, url); setTypeBadge(type==="mp4"?"mp4":"dash"); };
  vid.onerror   = () => { showOverlay(false); setStatus("err", "Playback error", url); };
}

function loadEmbed(url) {
  const vid = document.getElementById("vid");
  const ifr = document.getElementById("iframe-player");
  vid.style.display = "none";
  ifr.style.display = "block";
  ifr.src = url;
  // iframe fires load even on error pages, so just remove spinner after a moment
  ifr.onload = () => { showOverlay(false); setStatus("ok", "Embed loaded", url); setTypeBadge("embed"); };
  setTimeout(() => showOverlay(false), 3000); // fallback
}

async function loadTxtPlaylist(url) {
  // Fetch the .txt file, scan each line for a playable URL
  try {
    // Try direct first, then CORS proxy
    let text = null;
    try {
      const r = await fetch(url, { signal:AbortSignal.timeout(10000) });
      if(r.ok) text = await r.text();
    } catch {}

    if(!text && activeProxy) {
      const r = await fetch(activeProxy.wrap(url), { signal:AbortSignal.timeout(10000) });
      if(r.ok) text = await r.text();
    }

    if(!text) throw new Error("Could not fetch .txt file");

    const lines = text.split("\n").map(l=>l.trim()).filter(l=>l.startsWith("http"));
    if(!lines.length) throw new Error("No URLs found in .txt file");

    // Render all found URLs in the stream list as a group
    const existing = document.getElementById("streamList");
    const group = document.createElement("div");
    group.className = "server-group";
    const label = document.createElement("div");
    label.className = "server-label";
    label.textContent = "txt playlist";
    group.appendChild(label);

    lines.forEach(line => {
      const t = detectType(line);
      const item = document.createElement("div");
      item.className = "stream-item";
      item.innerHTML = `
        <span class="type-tag ${t}">${t.toUpperCase()}</span>
        <span class="stream-url-text" title="${line}">${line}</span>
        <span class="play-icon">▶</span>`;
      item.addEventListener("click", () => playStream(line, t, item));
      group.appendChild(item);
    });
    existing.prepend(group);

    // Auto-play the first URL
    const first = lines[0];
    const firstType = detectType(first);
    showOverlay(false);
    setStatus("ok", `TXT: found ${lines.length} URL(s) — playing first`, url);
    setTypeBadge("txt");
    loadMedia(first, firstType);

  } catch(e) {
    showOverlay(false);
    setStatus("err", `TXT error: ${e.message}`, url);
  }
}

// ═══════════════════════════════════════════════════════════════════
// UI helpers
// ═══════════════════════════════════════════════════════════════════
function showOverlay(show, msg="") {
  const ov = document.getElementById("overlay");
  document.getElementById("spinner").style.display = show ? "block" : "none";
  document.getElementById("overlayMsg").textContent = msg;
  ov.classList.toggle("hidden", !show);
}
function setStatus(type, label, url="") {
  const bar = document.getElementById("statusBar");
  const cls = type==="ok"?"ok":type==="err"?"err":"warn";
  const short = url.length>55 ? url.slice(0,52)+"…" : url;
  bar.innerHTML = `<span><span class="dot ${cls}"></span>${label}</span>`
    + (url ? `<span id="activeBadge"></span><span style="color:var(--muted);font-size:.68rem;word-break:break-all">${short}</span>` : "");
}
function setTypeBadge(type) {
  const el = document.getElementById("activeBadge");
  if(!el) return;
  const map = { hls:"badge-hls", mp4:"badge-mp4", dash:"badge-dash", txt:"badge-txt", embed:"badge-embed" };
  el.className = `media-type-badge ${map[type]||""}`;
  el.textContent = type.toUpperCase();
}
function setFetchStatus(msg, cls="") {
  const el = document.getElementById("fetchStatus");
  el.textContent = msg; el.className = `fetch-status ${cls}`;
}

// auto-load from URL params: ?tmdb=280  or  ?tmdb=1396&type=tv&season=1&episode=1
(function(){
  const p = new URLSearchParams(window.location.search);
  const tmdb = p.get("tmdb")||p.get("id");
  if(tmdb){
    document.getElementById("tmdbId").value = tmdb;
    if(p.get("type")==="tv"){
      document.getElementById("mtype").value = "tv";
      document.getElementById("epRow").style.display = "flex";
      if(p.get("season"))  document.getElementById("season").value  = p.get("season");
      if(p.get("episode")) document.getElementById("episode").value = p.get("episode");
    }
    fetchStreams();
  }
})();
</script>
</body>
</html>